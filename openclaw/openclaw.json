{
  "gateway": {
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "openai/doubao-seed-2-0-pro-260215",
      "models": {
        "openai/doubao-seed-2-0-pro-260215": {}
      },
      "memorySearch": {
        "provider": "gemini",
        "model": "gemini-embedding-001",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        }
      },
      "compaction": {
        "memoryFlush": {
          "enabled": true
        }
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true,
        "maxResults": 10
      },
      "fetch": {
        "enabled": true,
        "maxCharsCap": 50000
      }
    },
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 10,
      "criticalThreshold": 20
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks",
    "defaultSessionKey": "hook:blog",
    "allowRequestSessionKey": false
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "48h"
  },
  "memory": {
    "backend": "builtin"
  }
}
