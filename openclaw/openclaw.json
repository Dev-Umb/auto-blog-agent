{
  "gateway": {
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "models": {
    "providers": {
      "ark": {
        "baseUrl": "http://llm-proxy:4010/api/v3",
        "api": "openai-completions",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "doubao-seed-2-0-pro-260215",
            "name": "Doubao Seed 2.0 Pro",
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      },
      "gemini": {
        "baseUrl": "http://llm-proxy:4010/api/v3",
        "api": "openai-completions",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "gemini-2.0-flash",
            "name": "Gemini 2.0 Flash",
            "contextWindow": 1048576,
            "maxTokens": 8192
          }
        ]
      },
      "lkeap": {
        "baseUrl": "http://llm-proxy:4010/api/v3",
        "api": "openai-completions",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5",
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "lkeap/glm-5",
      "memorySearch": {
        "provider": "gemini",
        "model": "gemini-embedding-001",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        }
      },
      "compaction": {
        "memoryFlush": {
          "enabled": true
        }
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": false,
        "maxResults": 10
      },
      "fetch": {
        "enabled": true,
        "maxCharsCap": 50000
      }
    },
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 10,
      "criticalThreshold": 20
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks",
    "defaultSessionKey": "hook:blog",
    "allowRequestSessionKey": false
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "48h"
  },
  "memory": {
    "backend": "builtin"
  }
}